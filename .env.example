GEMINI_API_KEY=your_gemini_api_key_here
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password_here
LINKEDIN_CLIENT_ID=your_linkedin_app_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_app_client_secret
# Optional; must match LinkedIn app Authorized redirect URLs exactly (default: http://127.0.0.1:8765/oauth/callback)
# LINKEDIN_REDIRECT_URI=http://127.0.0.1:8765/oauth/callback
LINKEDIN_ACCESS_TOKEN=your_linkedin_oauth_access_token_here
# Set automatically by scripts/linkedin_oauth_local.py from OpenID id_token if userinfo API fails
# LINKEDIN_MEMBER_SUB=
CHROMA_PERSIST_DIR=./data/chroma
POST_CALENDAR_PATH=./data/post_calendar.csv
SCHEDULE_HOUR=12
SCHEDULE_MINUTE=15
TIMEZONE=Europe/Madrid
DRY_RUN=false
